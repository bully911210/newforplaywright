{
  "name": "mmx-portable",
  "version": "1.0.0",
  "description": "Portable single-file MMX automation (embedded Chromium, dashboard, poller).",
  "private": true,
  "main": "dist/bundle.cjs",
  "bin": "dist/bundle.cjs",
  "scripts": {
    "bundle": "node build.mjs",
    "stage-chromium": "node stage-chromium.mjs",
    "package": "pkg . --targets node20-win-x64 --output dist/MMX-Portable.exe --compress Brotli",
    "all": "npm run bundle && npm run stage-chromium && npm run package"
  },
  "dependencies": {
    "playwright": "1.58.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@yao-pkg/pkg": "^6.4.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  },
  "pkg": {
    "targets": ["node20-win-x64"],
    "assets": [
      "assets/chromium/**/*",
      "node_modules/playwright/**/*",
      "node_modules/playwright-core/**/*"
    ],
    "scripts": [
      "node_modules/playwright/lib/**/*.js",
      "node_modules/playwright-core/lib/**/*.js"
    ],
    "outputPath": "dist"
  }
}
